# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Camera ────────────────────────────────────────────────────────────────────
# Full sensor resolution used as the capture mode (--mode) so the entire FOV
# is captured; rpicam-vid then downscales to OUTPUT_WIDTHxOUTPUT_HEIGHT.
# Set to 0 to let rpicam-vid choose automatically (may crop the FOV).
SENSOR_WIDTH=4656
SENSOR_HEIGHT=3496
OUTPUT_WIDTH=1440
OUTPUT_HEIGHT=1080
CAMERA_FRAMERATE=30
MJPEG_FPS=30

# ── Snapshot worker ───────────────────────────────────────────────────────────
SNAPSHOT_INTERVAL_SEC=1
SNAPSHOT_BUFFER_SIZE=10

# ── Inference scheduler (OpenAI-compatible) ───────────────────────────────────
# Base URL of the OpenAI-compatible VLM server (no trailing slash)
# Endpoint called: {INFERENCE_API_URL}/v1/chat/completions
INFERENCE_API_URL=http://100.122.141.97:8080
# INFERENCE_API_URL=http://10.42.0.244:8080

# API key — use "none" or any placeholder if the server has no auth
INFERENCE_API_KEY=none

# Model name as recognised by the server (e.g. llava, llava-1.6, qwen-vl)
INFERENCE_MODEL=qwen_finetune

# System / user prompt sent with every inference request
INFERENCE_PROMPT="You are an indoor mobile robot navigation risk assessment agent.\n\nAnalyze two consecutive forward-facing frames and assess the safety of the robot's current path.\n\nYour goals:\n1. Identify hazards on the current moving path\n2. Estimate the minimum visible traversable free-space width ahead in cm\n3. Decide whether the robot (30cm) can safely pass through the gap (if there is one)\n4. Choose the next action\n\nHazards examples:\n- blocked path\n- narrow passage\n- clutter\n- dynamic obstacle\n- slippery floor\n- uneven surface\n- drop-off or hole\n- stairs / height change\n- restricted area / sign\n- get-stuck risk\n\nDecision rules:\n- NO-GO: blocked path, too-narrow free space, structural hazard, restricted area, or clear get-stuck risk\n- CAUTION: passable but limited free space, potential hazard, uncertainty, or dynamic risk\n- GO: wide enough free space and no major hazard\n\nAction rules:\n- Choose Move Forward when GO is indicated.\n- Choose Slow Down when caution is indicated and the forward path is passable but limited or uncertain.\n- Choose Stop when NO-GO is indicated and no clearly safer side direction is visible.\n- Choose Steer Left only when caution is indicated and the left side is visibly more open than the forward path and right side.\n- Choose Steer Right only when caution is indicated and the right side is visibly more open than the forward path and left side.\n- Do not choose Steer Left or Steer Right unless there is clear visible evidence for that side.\n\nRequirements:\n- Use both frames to do a short analysis\n- Base judgment only on visible evidence\n- The output must be a valid JSON object\n\nOutput:\n{\"analysis\": \"concise analysis based on visible evidence\", \"status\": {\"cat\": \"GO | CAUTION | NO-GO\", \"hazards\": \"string or none\", \"free_space\": null}, \"action\": \"Move Forward | Slow Down | Stop | Steer Right | Steer Left\"}"

# How often to fire inference (seconds)
INFERENCE_INTERVAL_SEC=2

# How many buffered frames to include per request
INFERENCE_FRAMES=2

# HTTP timeout for the inference API call (seconds)
INFERENCE_TIMEOUT_SEC=30

# ── Live YOLO detection overlay ──────────────────────────────────────────────
LIVE_DETECTION_ENABLED=1
YOLO_MODEL_PATH=yolo26n_ncnn_model
YOLO_PREFER_NCNN=1
YOLO_CONF=0.35
YOLO_IOU=0.45
YOLO_INFER_EVERY_N=2
YOLO_IMGSZ=640
